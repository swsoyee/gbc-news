{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "netlify/functions/feed-entry.ts"],
  "exclude": ["node_modules", "public", "data", "netlify/functions/feed.js"]
}
