{
  "name": "gbc-news",
  "version": "0.1.0",
  "private": true,
  "description": "低成本官网资讯抓取，提供 RSS 与 iCal 订阅",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "scrape:gbc": "tsx scripts/scrape-gbc.ts",
    "scrape:firstriff": "tsx scripts/scrape-firstriff.ts",
    "scrape:collabo-cafe": "tsx scripts/scrape-collabo-cafe.ts",
    "scrape": "npm run scrape:gbc && npm run scrape:firstriff && npm run scrape:collabo-cafe",
    "build:feeds": "tsx scripts/build-feeds.ts",
    "build:function": "node scripts/bundle-function.mjs",
    "build": "npm run typecheck && npm run build:function && npm run build:feeds"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.32",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
