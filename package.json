{
  "name": "gbc-news",
  "version": "0.1.0",
  "private": true,
  "description": "低成本官网资讯抓取，提供 RSS 与 iCal 订阅",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "npm run lint && npm run format:check",
    "prepare": "git config core.hooksPath .githooks",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "scrape:gbc": "tsx scripts/scrape-gbc.ts",
    "scrape:firstriff": "tsx scripts/scrape-firstriff.ts",
    "scrape:collabo-cafe": "tsx scripts/scrape-collabo-cafe.ts",
    "scrape:gamepedia": "tsx scripts/scrape-gamepedia.ts",
    "scrape": "tsx scripts/scrape-all.ts",
    "build:feeds": "tsx scripts/build-feeds.ts",
    "backfill:body-text": "tsx scripts/backfill-body-text.ts",
    "enrich:list-pending": "tsx scripts/enrich-list-pending.ts",
    "enrich:validate": "tsx scripts/enrich-validate.ts",
    "dedupe:candidates": "tsx scripts/dedupe-candidates.ts",
    "build:function": "node scripts/bundle-function.mjs",
    "build:web": "node scripts/bundle-web.mjs",
    "generate:favicon": "node scripts/generate-favicon.mjs",
    "build": "npm run typecheck && npm run build:function && npm run build:web && npm run build:feeds"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.32",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
